{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/pricing/?$",
      "dest": "/pricing.html"
    },
    {
      "src": "^/como-funciona/?$",
      "dest": "/como-funciona.html"
    }
  ]
}
